# Brain Memory — Environment Configuration
# Copy this file to .env and fill in your API keys.

# ── LLM Provider Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Configuration ──────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o             # model name for the chosen provider
LLM_BASE_URL=                 # leave blank for default; set for local / proxy endpoints

# ── Proxy Server ────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8800

# ── Embedding Model ─────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# ── Data Paths ──────────────────────────────────────────────────────
DATA_DIR=./data
EPISODIC_DB_PATH=./data/episodic.db
SEMANTIC_GRAPH_PATH=./data/semantic_graph.json
